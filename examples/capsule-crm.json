      "name": "search-pagination-test",
      "tool": "search_contacts",
      "params": {"q": "Tuco", "page": "1", "perPage": "2"},
      "workflow_step": "Test: does perPage actually limit results?",
      "assertions": [
        "Returns 2 or fewer results",
        "Same field quality as read-1"
      ]
    },
    {
