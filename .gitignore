# Eval workspaces are run output, not source. They're created by /eval-run or
# /eval-capture and can always be regenerated by re-running an eval.
eval-workspace/
eval-workspace-*/
evaluate-workspace/
evaluate-workspace-*/

# Generated reports and raw response captures
*.html
_raw_*.json
raw_response.txt

# eval-tests.json files at the repo root are user data. Examples committed
# under examples/ are tracked deliberately.
/eval-tests.json
/run_summary.json
/grades_summary.json

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# Virtualenvs
.venv/
venv/
env/

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*~
